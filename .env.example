# ─────────────────────────────────────────────────────────────────────────────
# Ndalem Pleret — Environment Variables
# Copy file ini menjadi .env lalu isi nilai-nilainya.
# JANGAN commit file .env ke Git — sudah ada di .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (wajib)
# Gratis di: https://supabase.com atau https://neon.tech
DATABASE_URL=postgresql://user:password@host:5432/database

# Resend API Key untuk kirim email (HTTPS — tidak diblokir Railway)
# Daftar gratis di: https://resend.com → API Keys → Create API Key
# Wajib verifikasi domain ndalempleret.com di Resend → Domains sebelum production
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Admin panel password
ADMIN_PASSWORD=your_secure_admin_password

# Google Calendar Integration (opsional — untuk sinkron kalender otomatis)
# Cara setup: https://console.cloud.google.com → OAuth 2.0 → Calendar API
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Server port (default: 5000 — Railway akan set otomatis via PORT env var)
# PORT=5000
